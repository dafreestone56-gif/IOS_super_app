<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Playground</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.personal.playgroundtoolkit</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ultimatetoolkit</string>
			</array>
		</dict>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Bluetooth scanning is used to discover, inspect, and automate nearby BLE peripherals.</string>
	<key>NSCameraUsageDescription</key>
	<string>Camera access powers QR scanning, OCR, Vision analysis, and developer capture tools.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Face ID can protect sensitive developer tools and stored secrets.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Local network access supports diagnostics, Bonjour discovery, HTTP clients, and automation triggers.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
		<string>_https._tcp</string>
		<string>_ssh._tcp</string>
		<string>_workstation._tcp</string>
		<string>_ipp._tcp</string>
		<string>_services._dns-sd._udp</string>
	</array>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Location enables geofence automations, heading, compass, and network context when you choose those tools.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Location enables heading, compass, geofence automations, and network context when you choose those tools.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Microphone access powers audio levels, waveform analysis, recording, and speech tools.</string>
	<key>NFCReaderUsageDescription</key>
	<string>NFC access is used to read and write supported NDEF tags when you start a scan.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Photo library access lets you analyze images and inspect metadata when selected.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Speech recognition is used to transcribe audio when you choose speech tools.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>audio</string>
		<string>fetch</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
